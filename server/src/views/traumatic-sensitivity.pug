doctype html
html
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Type Info
    style.
      body { font-family: Arial, sans-serif; background-color: #2c3e50; color: #ffffff; padding: 20px; }
      .container { max-width: 600px; margin: auto; background: #34495e; padding: 20px; border-radius: 8px; }
      .section { border-top: 1px solid #ffffff; padding-top: 15px; }
      .description { text-align: center; font-size: 16px; line-height: 1.6; }
      ul { padding-left: 20px; }
      li { margin-bottom: 10px; }

  body
    .container
      if typeInfo
        p.description 🔍 #{typeInfo.description}

        if typeInfo.insights
          .section
            h3 #{typeInfo.insights.title}
            ul
              each insight in typeInfo.insights.text
                li 💡 #{insight}

        if typeInfo.strengths
          .section
            h3 #{typeInfo.strengths.title}
            ul
              each strength in typeInfo.strengths.list
                li ✅ #{strength}

        if typeInfo.challenges
          .section
            h3 #{typeInfo.challenges.title}
            ul
              each challenge in typeInfo.challenges.list
                li 🔴 #{challenge}

        if typeInfo.recommendations
          .section
            h3 #{typeInfo.recommendations.title}
            ul
              each recommendation in typeInfo.recommendations.list
                li 📌 #{recommendation}

        if typeInfo.retakeConditions
          .section
            h3 ⏳ #{typeInfo.retakeConditions.title}
            ul
              each condition in typeInfo.retakeConditions.list
                li #{condition}

        if typeInfo.summary
          .summary
            h3 📜 #{typeInfo.summary.title}
            p #{typeInfo.summary.text}
